    {
        "id": "9f3ad1ade9dd633f",
        "type": "function",
        "z": "3431837e7a804560",
        "name": "reponce",
        "func": "// Le résultat de la mise à jour est maintenant dans msg.payload[0] (selon le driver utilisé)\nlet data = msg.payload[0] || msg.payload;\n\n// Construire le message de réponse avec les données réelles de la base\nmsg.payload = {\n    \"status\": \"success\",\n    \"lot\": data.nom,\n    \"max\": data.max,\n    \"min\": data.min,\n    \"date_debut\": data.date_debut,\n    \"duree_jours\": data.duree_jours\n};\n\nreturn msg;",
