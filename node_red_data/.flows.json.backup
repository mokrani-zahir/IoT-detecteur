    {
        "id": "e8775d9e78046f11",
        "type": "function",
        "z": "3431837e7a804560",
        "name": "Récupérer les paramètres",
        "func": "let lot = msg.req.params.lot;\nlet rawMax = msg.req.query.max;\nlet rawMin = msg.req.query.min;\nlet date_debut = msg.req.query.date_debut;\nlet duree_jours = msg.req.query.duree_jours;\n\n// Fonction utilitaire pour traiter la valeur\nfunction processValue(val) {\n    if (val === undefined || val === null || val === '') return null; // \"Ne rien faire\"\n    if (val === 'false') return 'false'; // \"Mettre à NULL\"\n    return parseFloat(val); // \"Mettre à jour avec une valeur\"\n}\n\nmsg.params = [lot, processValue(rawMax), processValue(rawMin),date_debut,duree_jours];\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 690,
        "y": 720,
        "wires": [
            [
                "b6448b8715e3c8cf"
            ]
        ]
    },
    {
        "id": "b6448b8715e3c8cf",
        "type": "postgresql",
        "z": "3431837e7a804560",
        "name": "Récupérer les mesures par plage",
        "query": "UPDATE public.capteurs \nSET \n    -- Gestion du max\n    max = CASE \n            WHEN $2::TEXT = 'false' THEN NULL \n            WHEN $2 IS NOT NULL THEN $2::DOUBLE PRECISION \n            ELSE max \n          END,\n    -- Gestion du min\n    min = CASE \n            WHEN $3::TEXT = 'false' THEN NULL \n            WHEN $3 IS NOT NULL THEN $3::DOUBLE PRECISION \n            ELSE min \n          END,\n    -- Gestion de la date_debut (si $4 est passé, on met à jour, sinon on garde la date actuelle)\n    date_debut = COALESCE($4::DATE, date_debut),\n    -- Gestion de la duree_jours (si $5 est passé, on met à jour, sinon on garde la valeur existante)\n    duree_jours = COALESCE($5::INTEGER, duree_jours)\nWHERE nom = $1::TEXT\nRETURNING *;",
        "postgreSQLConfig": "91e595620c23b1e6",
        "split": false,
        "rowsPerMsg": "1",
        "outputs": 1,
        "x": 1000,
        "y": 720,
        "wires": [
            [
                "9f3ad1ade9dd633f"
            ]
        ]
    },
    {
        "id": "13c843f2429ebd21",
        "type": "http in",
        "z": "3431837e7a804560",
