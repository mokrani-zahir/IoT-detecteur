    {
        "id": "151b290140ac2dd3",
        "type": "function",
        "z": "3431837e7a804560",
        "name": "Generation de tocken JWT",
        "func": "const jwt = global.get('jwt');\nconst secretKey = global.get('jwtSecret');\n\n// 1. Récupération de la durée envoyée par le client (en secondes)\n// Si non fourni, on utilise 3600 secondes (1 heure) par défaut\nconst dureeEnSecondes = msg.req.query.expiresIn || 3600;\n\n// 2. Vérification simplifiée (à adapter avec votre base de données)\nif (msg.payload.username === \"admin\" && msg.payload.password === \"password123\") {\n    \n    // 3. Génération du token avec la durée calculée\n    const token = jwt.sign(\n        { username: msg.payload.username }, \n        secretKey, \n        { expiresIn: parseInt(dureeEnSecondes) } // expiresIn accepte les nombres (secondes)\n    );\n    \n    msg.payload = { \n        status: \"success\", \n        token: token,\n        expiresIn: dureeEnSecondes\n    };\n    msg.statusCode = 200;\n} else {\n    msg.payload = { status: \"error\", msg: \"Identifiants invalides\" };\n    msg.statusCode = 401;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 120,
        "wires": [
            [
                "62a4c32bea8bec93"
            ]
        ]
    },
    {
        "id": "62a4c32bea8bec93",
        "type": "http response",
        "z": "3431837e7a804560",
        "name": "",
        "statusCode": "",
        "headers": {},
        "x": 1550,
        "y": 120,
        "wires": []
    },
    {
        "id": "36a1be992c875243",
        "type": "function",
        "z": "3431837e7a804560",
        "name": "Auth Middleware",
        "func": "const jwt = global.get('jwt');\nconst secretKey = global.get('jwtSecret');\n\nconst authHeader = msg.req.headers['authorization'];\n\n// Vérifier si le header existe et suit le format \"Bearer <token>\"\nif (authHeader && authHeader.startsWith('Bearer ')) {\n    const token = authHeader.split(' ')[1];\n    try {\n        const decoded = jwt.verify(token, secretKey);\n        msg.user = decoded; // On stocke les infos utilisateur pour la suite\n        return msg; // Le token est valide, on continue\n    } catch (err) {\n        msg.res.status(403).send({\n            status: \"error\",\n            msg: \"Token invalide ou expiré\"\n        });\n    }\n} else {\n    msg.res.status(401).send({\n        status: \"error\",\n        msg: \"Accès non autorisé : Token manquant\"\n    });\n    return null; // On bloque la requête\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 280,
