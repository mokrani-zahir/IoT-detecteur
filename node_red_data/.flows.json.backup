        "type": "postgresql",
        "z": "3431837e7a804560",
        "name": "Récupérer les mesures par plage",
        "query": "SELECT *\nFROM alert\nWHERE nom = $1\nAND date BETWEEN $2 AND $3\nORDER BY date DESC\nLIMIT $4;",
        "postgreSQLConfig": "91e595620c23b1e6",
