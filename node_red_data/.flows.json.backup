    },
    {
        "id": "05bcb295821a639b",
        "type": "function",
        "z": "e4aa9b15e1aa2193",
        "name": "Creation requet SQL",
        "func": "msg.params = [msg.topic, parseFloat(msg.payload)];\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 460,
        "wires": [
            [
                "0254f24c290f2f46",
                "8d6a6c6d6c6cf6f3"
            ]
        ]
    },
    {
        "id": "8d6a6c6d6c6cf6f3",
        "type": "postgresql",
        "z": "e4aa9b15e1aa2193",
        "name": "",
        "query": "SELECT \n    $1::TEXT AS nom, \n    $2::DOUBLE PRECISION AS valeu,\n    CASE \n        WHEN ($2::DOUBLE PRECISION) > max OR ($2::DOUBLE PRECISION) < min THEN true \n        ELSE false \n    END AS alerte\nFROM public.capteurs \nWHERE nom = $1::TEXT;",
        "postgreSQLConfig": "91e595620c23b1e6",
        "split": false,
        "rowsPerMsg": 1,
        "outputs": 1,
        "x": 790,
        "y": 540,
        "wires": [
            [
                "acafc456e7e77851"
            ]
        ]
    },
    {
        "id": "acafc456e7e77851",
        "type": "switch",
        "z": "e4aa9b15e1aa2193",
        "name": "",
        "property": "payload[0].alerte",
        "propertyType": "msg",
        "rules": [
            {
                "t": "true"
            }
        ],
        "checkall": "true",
        "repair": false,
        "outputs": 1,
        "x": 980,
        "y": 540,
        "wires": [
            [
                "8fc5cb06df1217ac"
            ]
        ]
    },
    {
        "id": "8fc5cb06df1217ac",
        "type": "function",
        "z": "e4aa9b15e1aa2193",
        "name": "save alert",
        "func": "if (msg.payload && msg.payload.length > 0) {\n    let data = msg.payload[0]; // On récupère l'objet dans le tableau\n    \n    // Vous pouvez maintenant manipuler vos variables\n    let nomCapteur = data.nom;\n    let valeurRecue = data.valeu; // Attention, vérifiez si c'est 'valeu' ou 'valeur' dans votre base\n    let estEnAlerte = data.alerte; // Ceci sera true ou false\n    \n    // Exemple : Créer un message spécifique pour une alerte\n    if (estEnAlerte === true) {\n        msg.params = [nomCapteur, parseFloat(valeurRecue)];\n        return msg;\n    }\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1160,
        "y": 540,
        "wires": [
            [
                "18911ef572c45b75"
            ]
        ]
    },
