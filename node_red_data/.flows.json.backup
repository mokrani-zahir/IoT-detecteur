    {
        "id": "0254f24c290f2f46",
        "type": "postgresql",
        "z": "e4aa9b15e1aa2193",
        "name": "Base de donnée",
        "query": "INSERT INTO mesures (nom, valeur, date) VALUES ($1, $2, NOW())",
        "postgreSQLConfig": "91e595620c23b1e6",
