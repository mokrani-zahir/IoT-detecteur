    {
        "id": "e3f77b90e936a758",
        "type": "postgresql",
        "z": "3431837e7a804560",
        "name": "Récupérer les mesures",
        "query": "SELECT *\nFROM mesures\nWHERE nom = $1\nORDER BY date DESC\nLIMIT $2;",
        "postgreSQLConfig": "91e595620c23b1e6",
        "split": false,
        "rowsPerMsg": "1",
        "outputs": 1,
        "x": 1290,
        "y": 280,
        "wires": [
            [
                "fa7df65394a057b6"
            ]
        ]
    },
    {
        "id": "fa7df65394a057b6",
        "type": "http response",
        "z": "3431837e7a804560",
        "name": "",
        "statusCode": "",
        "headers": {},
        "x": 1550,
        "y": 280,
        "wires": []
    },
    {
        "id": "7b04baa8aa7a7aad",
        "type": "function",
        "z": "3431837e7a804560",
        "name": "Récupérer les paramètres",
        "func": "let lot = msg.req.params.lot;\n\nlet limit = parseInt(msg.req.query.limit || 10);\nif (isNaN(limit) || limit <= 0) limit = 10;\n\nlet from = msg.req.query.from;\nlet to = msg.req.query.to;\n\n// construire paramètres dynamiques\nmsg.params = [lot];\n\nmsg.useDate = false;\n\n// si date existe → on active filtre\nif (from && to) {\n    msg.useDate = true;\n    msg.params.push(from, to);\n}\n\n// toujours ajouter limit à la fin\nmsg.params.push(limit);\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 690,
        "y": 280,
        "wires": [
            [
                "cb809e9ad3d54438"
            ]
        ]
    },
    {
        "id": "64b1c1e9382bd484",
        "type": "postgresql",
        "z": "3431837e7a804560",
        "name": "Récupérer les mesures par plage",
        "query": "SELECT *\nFROM mesures\nWHERE nom = $1\nAND date BETWEEN $2 AND $3\nORDER BY date DESC\nLIMIT $4;",
        "postgreSQLConfig": "91e595620c23b1e6",
        "split": false,
        "rowsPerMsg": "1",
        "outputs": 1,
        "x": 1320,
        "y": 340,
        "wires": [
            [
                "fa7df65394a057b6"
            ]
        ]
    },
